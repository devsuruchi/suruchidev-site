<!DOCTYPE html>
<html lang="ne">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yuvaan's Annaprashan Invitation</title>
    <!-- Google Fonts for Nepali and English -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&family=Yantramanav:wght@900&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #D4AF37;
            --maroon: #7b0000;
            --cream: #fff9e6;
            --bronze: #cd7f32;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--maroon);
            font-family: 'Poppins', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Falling Marigold Animation */
        .petal {
            position: absolute;
            background-color: #ffcc00;
            width: 12px;
            height: 12px;
            border-radius: 50% 0 50% 0;
            z-index: 1;
            animation: fall linear infinite;
        }

        @keyframes fall {
            0% { transform: translateY(-10vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
        }

        /* The Main Card */
        .card {
            background: var(--cream);
            width: 90%;
            max-width: 450px;
            padding: 30px;
            text-align: center;
            border: 10px double var(--gold);
            border-radius: 30px;
            position: relative;
            z-index: 10;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        /* Anniversary Title */
        h1 {
            font-family: 'Yantramanav', sans-serif;
            color: var(--maroon);
            font-size: 3.5rem;
            margin: 0;
            padding: 0;
            line-height: 1;
        }

        .english-title {
            font-size: 1.2rem;
            color: var(--maroon);
            letter-spacing: 2px;
            text-transform: uppercase;
            font-weight: 600;
        }

        /* Central Image Section */
        .photo-container {
            position: relative;
            width: 200px;
            height: 200px;
            margin: 60px auto; /* Space for the 84 bowls */
        }

        .yuvaan-photo {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 5px solid var(--gold);
            object-fit: cover;
            position: relative;
            z-index: 5;
            background: #fff;
        }

        /* 84 Byanjan (Bowls) Wrapper */
        .bowls-orbit {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 100%;
            height: 100%;
            transform: translate(-50%, -50%);
            z-index: 2;
        }

        .mini-bowl {
            position: absolute;
            width: 12px;
            height: 8px;
            background: var(--bronze);
            border: 1px solid gold;
            border-radius: 0 0 10px 10px;
            box-shadow: inset 0 -2px 2px rgba(0,0,0,0.3);
        }

        /* Weaning Ceremony Graphic */
        .baby-graphic {
            font-size: 2rem;
            margin-bottom: 10px;
        }

        /* Event Details */
        .info-box {
            border-top: 2px solid var(--gold);
            margin-top: 20px;
            padding-top: 20px;
            color: var(--maroon);
        }

        .date-text {
            font-size: 1.4rem;
            font-weight: 600;
        }

        .venue-tag {
            display: inline-block;
            background: var(--maroon);
            color: white;
            padding: 5px 20px;
            border-radius: 50px;
            margin-top: 10px;
            font-size: 1.1rem;
        }

        .blessing-text {
            font-style: italic;
            font-size: 0.9rem;
            margin-top: 20px;
        }

        /* Rotating Animation */
        @keyframes rotateOrbit {
            from { transform: translate(-50%, -50%) rotate(0deg); }
            to { transform: translate(-50%, -50%) rotate(360deg); }
        }

        .bowls-orbit {
            animation: rotateOrbit 40s linear infinite;
        }
    </style>
</head>
<body>

    <!-- Falling Petals Container -->
    <div id="petals"></div>

    <div class="card">
        <div class="baby-graphic">👶🥣🍼</div>
        <p style="margin: 0; color: #555;">Join us for the Weaning Ceremony of</p>
        <h2 style="color: var(--gold); margin: 5px 0; font-size: 2rem;">YUVAAN</h2>

        <!-- Photo Section with 84 Bowls -->
        <div class="photo-container">
            <!-- 84 Bowls will be generated here by JS -->
            <div class="bowls-orbit" id="orbit"></div>
            <!-- Yuvaan's Picture -->
            <img src="yuvaan_pp.jpg" alt="Yuvaan" class="yuvaan-photo">
        </div>

        <div class="english-title">Annaprashan</div>
        <h1>अन्नप्राशन</h1>
        
        <p style="font-weight: 600; color: var(--maroon); margin-top: 5px;">
            Celebrating Chaurasi Byanjan
        </p>

        <div class="info-box">
            <div class="date-text">7 Baisakh 2083</div>
            <div style="color: #666;">20th April 2026</div>
            <div class="venue-tag">📍 Jorpati, Kathmandu</div>
        </div>

        <p class="blessing-text">"Your presence and blessings will make Yuvaan's first meal even sweeter."</p>
    </div>

    <script>
        // 1. Generate 84 small bowls representing Chaurasi Byanjan
        const orbit = document.getElementById('orbit');
        const totalBowls = 84;
        const radius = 130; // How far the bowls sit from the center

        for (let i = 0; i < totalBowls; i++) {
            const bowl = document.createElement('div');
            bowl.className = 'mini-bowl';
            
            // Calculate position in a circle
            const angle = (i / totalBowls) * 360;
            const x = 100 + radius * Math.cos(angle * Math.PI / 180) - 6;
            const y = 100 + radius * Math.sin(angle * Math.PI / 180) - 4;
            
            bowl.style.left = x + 'px';
            bowl.style.top = y + 'px';
            // Vary colors slightly for realism
            if (i % 3 === 0) bowl.style.background = '#d4af37'; 
            
            orbit.appendChild(bowl);
        }

        // 2. Falling Marigold Petals effect
        const petalsContainer = document.getElementById('petals');
        function createPetal() {
            const petal = document.createElement('div');
            petal.className = 'petal';
            petal.style.left = Math.random() * 100 + 'vw';
            petal.style.animationDuration = (Math.random() * 3 + 3) + 's';
            petal.style.opacity = Math.random();
            petalsContainer.appendChild(petal);
            setTimeout(() => petal.remove(), 6000);
        }
        setInterval(createPetal, 200);
    </script>
</body>
</html>
