<!DOCTYPE html>
<html lang="ne">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yuvaan's Annaprashan Ceremony</title>
    
    <!-- External Scripts (Matching your site's style) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Mukta:wght@400;700&family=Poppins:wght@300;600&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="invitation-style.css">
</head>
<body class="bg-slate-900 overflow-hidden">

    <!-- Animation Canvas for Falling Petals -->
    <div id="petal-container" class="fixed inset-0 pointer-events-none z-0"></div>

    <main class="relative z-10 min-h-screen flex items-center justify-center p-4">
        
        <!-- THE CARD -->
        <div class="invite-card bg-[#FFFDD0] max-w-md w-full rounded-[2.5rem] border-[10px] border-double border-[#D4AF37] p-8 text-center shadow-2xl overflow-hidden relative">
            
            <!-- Traditional Border Accent -->
            <div class="absolute top-0 left-0 w-full h-2 bg-[#800000]"></div>

            <header class="mb-6">
                <p class="text-[#800000] uppercase tracking-[0.3em] text-xs font-bold mb-2">Weaning Ceremony of</p>
                <h2 class="text-[#D4AF37] text-4xl font-extrabold tracking-tight">YUVAAN</h2>
            </header>

            <!-- THE 84 BYANJAN GRAPHIC -->
            <div class="relative w-56 h-56 mx-auto mb-8">
                <!-- Rotating Orbit for 84 Bowls -->
                <div id="bowls-orbit" class="absolute inset-0 z-0"></div>
                
                <!-- Yuvaan's Picture -->
                <div class="relative z-10 w-full h-full rounded-full border-4 border-[#D4AF37] overflow-hidden bg-slate-200 shadow-lg">
                    <img src="yuvaan_pp.jpg" alt="Yuvaan" class="w-full h-full object-cover" onerror="this.src='https://via.placeholder.com/400?text=Yuvaan';">
                </div>
            </div>

            <!-- ANNAPRASHAN IN DEVANAGARI -->
            <div class="mb-6">
                <h1 class="text-[#800000] text-6xl font-bold leading-none font-['Mukta']">अन्नप्राशन</h1>
                <p class="text-[#800000] font-semibold mt-2 opacity-80 italic">The Royal Feast of 84 Byanjan</p>
            </div>

            <!-- EVENT DETAILS -->
            <div class="border-y-2 border-[#D4AF37]/30 py-4 mb-6">
                <div class="text-[#800000] text-xl font-bold">7 Baisakh 2083</div>
                <div class="text-slate-500 text-sm font-medium">20th April 2026</div>
                
                <div class="mt-4 inline-flex items-center gap-2 bg-[#800000] text-white px-4 py-2 rounded-full text-sm">
                    <i data-lucide="map-pin" class="w-4 h-4"></i>
                    <span>Jorpati, Kathmandu</span>
                </div>
            </div>

            <!-- FOOTER -->
            <footer class="space-y-4">
                <p class="text-slate-600 text-xs italic">
                    Join us as our 5-month-old prince takes his first bite of tradition.
                </p>
                
                <a href="https://wa.me/?text=I+am+joining+Yuvaan's+Ceremony" class="inline-block w-full py-4 bg-[#D4AF37] text-[#800000] rounded-2xl font-black text-sm uppercase tracking-widest hover:bg-[#b8952e] transition-colors shadow-lg">
                    Send Blessings
                </a>
            </footer>

        </div>
    </main>

    <script src="invitation-logic.js"></script>
    <script>lucide.createIcons();</script>
</body>
</html>
